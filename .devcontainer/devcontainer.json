{
  // Dev container for the talk. It gives you everything to:
  //   - run the .NET 10 file-based samples in samples/ against GitHub Models,
  //   - build and serve the RevealJS presentation with npm, and
  //   - run demo/ChatApp (Aspire), since Docker is available via docker-in-docker.
  // See .devcontainer/README.md.
  "name": "dotnet-ai-building-blocks",

  // GA .NET 10 SDK image (includes git and a non-root vscode user).
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-10.0",

  "features": {
    // Node for the presentation build and the static server (serve.mjs).
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    // gh is handy for tokens and repo work.
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // az lets you sign in and configure Azure OpenAI (see .devcontainer/README.md).
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    // Docker so Aspire can run demo/ChatApp and its markitdown container.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // serve.mjs serves the built deck on 8000 (npm run preview).
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "Slides", "onAutoForward": "openPreview" }
  },

  // Install the deck's Node dependencies once, after the container is created.
  "postCreateCommand": "npm install",

  "containerEnv": {
    "DOTNET_NOLOGO": "1",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
  },

  // The samples read GITHUB_TOKEN, which needs the models:read permission.
  //   - Codespaces: nothing to do. Codespaces provides GITHUB_TOKEN automatically, and it works
  //     with GitHub Models out of the box (see the docs link in .devcontainer/README.md).
  //   - Local Dev Containers: create a PAT with models:read, export GITHUB_TOKEN on your host,
  //     then uncomment the line below to forward it in. We keep it commented because localEnv is
  //     not available in Codespaces and an empty value would shadow the provided token.
  // "remoteEnv": { "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}" },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit"
      ]
    }
  }
}
