<?xml version="1.0" encoding="utf-8"?>
<!-- Pin every restore in this repo to NuGet.org only, so a fresh clone builds
     the same way everywhere and doesn't depend on private or nightly feeds. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
