<?xml version="1.0" encoding="utf-8"?>
<!-- Scoped to the ChatApp demo only. The final demo showcases the real, in-flight RAG
     building blocks that are not on NuGet.org yet (Microsoft.Extensions.DataRetrieval from
     dotnet/extensions PR #7508, MEDIExtensions processors from CommunityToolkit/AI #10/#11,
     and the UglyToad.PdfPig.DataIngestion fork). We vendor those local -dev builds in
     ./local-packages so a fresh clone still builds. The file-based samples under /samples
     are unaffected (they use the repo-root nuget.config: NuGet.org only). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="local" value="./local-packages" />
  </packageSources>
</configuration>
